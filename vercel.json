{
  "crons": [
    {
      "path": "/api/daily-report",
      "schedule": "30 16 * * *"
    },
    {
      "path": "/api/rider-report",
      "schedule": "30 17 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
